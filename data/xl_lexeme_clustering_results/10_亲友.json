          },
          {
            "item_id": "亲友_anchor_3",
            "source": "anchor",
            "text": "周末亲友来家里做客，厨房里总是香气四溢。",
            "target_start": 2,
            "target_end": 4
          },
          {
            "item_id": "亲友_anchor_4",
